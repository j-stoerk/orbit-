# ORBIT — environment configuration (copy to .env and fill in)
# Everything is OPTIONAL. ORBIT runs fully on free keyless feeds without any of these.

# Claude-powered agent reasoning (without it, agents use deterministic heuristics)
# ANTHROPIC_API_KEY=sk-ant-...

# Real-time alert delivery
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...   # Slack / Discord / Teams / generic
# ALERT_EMAIL_TO=ops@example.org                            # needs SMTP_* below
# SMTP_HOST=smtp.example.org
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=alerts@orbit
# MONITOR_INTERVAL=120                                      # feed poll interval (seconds)

# Extra live data sources (free keys)
# FIRMS_MAP_KEY=            # NASA FIRMS active fires — firms.modaps.eosdis.nasa.gov/api/
# OPENAQ_API_KEY=           # OpenAQ v3 air quality — openaq.org
# VESSEL_API_KEY=           # VesselAPI AIS vessels + ports — vesselapi.com
# RELIEFWEB_APPNAME=        # ReliefWeb feed — register at reliefweb.int/help/api

# ACLED conflict data (requires Research/Partner/Enterprise tier — Open tier has no API access)
# ACLED_EMAIL=
# ACLED_PASSWORD=
